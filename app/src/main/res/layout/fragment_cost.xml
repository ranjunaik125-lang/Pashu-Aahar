<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F8E9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💰 Cost Tracker"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:layout_marginTop="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Compare Feed Costs"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginTop="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#E8F5E9"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Home-made"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:gravity="center"/>

                <TextView
                    android:id="@+id/tvHomeCost"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="₹40/day"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#2E7D32"
                    android:gravity="center"
                    android:layout_marginTop="8dp"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#FFEBEE"
                android:padding="12dp"
                android:layout_marginLeft="8dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Market Price"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:gravity="center"/>

                <TextView
                    android:id="@+id/tvMarketCost"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="₹65/day"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#C62828"
                    android:gravity="center"
                    android:layout_marginTop="8dp"/>

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFF8E1"
            android:padding="12dp"
            android:layout_marginTop="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💡 Monthly Savings"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#F57C00"/>

            <TextView
                android:id="@+id/tvSavings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="₹750/month"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#F57C00"
                android:gravity="center"
                android:layout_marginTop="8dp"/>

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cost Breakdown (Daily)"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:layout_marginTop="24dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🌽 Maize (2kg)"
                    android:textSize="14sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹22"
                    android:textSize="14sp"
                    android:textStyle="bold"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🥜 Cottonseed (1kg)"
                    android:textSize="14sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹18"
                    android:textSize="14sp"
                    android:textStyle="bold"/>

            </LinearLayout>

        </LinearLayout>

        <Button
            android:id="@+id/btnExportReport"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Export Report"
            android:textSize="18sp"
            android:backgroundTint="#2E7D32"
            android:layout_marginTop="24dp"/>

    </LinearLayout>

</ScrollView>